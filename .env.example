# Dahrk edge node configuration. Copy to .env and fill in.
# Flags (--hub-url, --token, --name) win over the matching variable.
# The legacy SKAKEL_* names are still accepted as aliases for each DAHRK_* variable.

# --- required ---
DAHRK_ENROL_TOKEN=

# --- hub (optional; defaults to wss://hub.dahrk.net) ---
# DAHRK_HUB_URL=wss://hub.dahrk.net

# --- identity (optional; the hub assigns/derives these otherwise) ---
# DAHRK_NODE_NAME=
# DAHRK_NODE_ID=
# DAHRK_TENANT_ID=

# --- runtimes & routing (optional) ---
# DAHRK_RUNTIMES=claude-code,codex,pi
# DAHRK_REPOS=
# DAHRK_CREDENTIAL_MODE=ambient

# --- local paths (optional; default under ~/.dahrk) ---
# DAHRK_STATE_DIR=
# DAHRK_WORKTREES_DIR=
# DAHRK_MIRRORS_DIR=

# --- credentials (ambient mode) ---
# DAHRK_GIT_TOKEN=

{
  "name": "dahrk-node",
  "version": "0.1.14",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "description": "The Dahrk node: deliberate edge/managed nodes that run deterministic multi-stage agent workflows per Linear issue, dispatched by the Dahrk hub.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dahrkai/dahrk-node.git"
  },
  "homepage": "https://github.com/dahrkai/dahrk-node#readme",
  "bugs": {
    "url": "https://github.com/dahrkai/dahrk-node/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint:changelog": "node scripts/lint-changelog.mjs",
    "check:changelog": "node scripts/check-changelog.mjs",
    "smoke": "bash scripts/smoke-pack.sh",
    "edge": "pnpm --filter @dahrk/edge-node dev",
    "release": "node scripts/release.mjs"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0"
  }
}
